# ---------- Antidote plugin manager ----------
source "${XDG_DATA_HOME:-$HOME/.local/share}/antidote/antidote.zsh"
antidote load ~/.zsh_plugins.txt

# ---------- Source all configs ----------
for config in ~/.zsh/config/*.zsh(N); do
  source "$config"
done

# ---------- Source all options ----------
for option in ~/.zsh/options/*.zsh(N); do
  source "$option"
done
